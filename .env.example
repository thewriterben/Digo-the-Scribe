# ─────────────────────────────────────────────────────────────────────────────
# Digo the Scribe — environment configuration template
# Copy this file to .env and fill in real values.
# NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
# Your Anthropic API key (required).
ANTHROPIC_API_KEY=

# Claude model to use (default shown; change only if instructed).
LLM_MODEL=claude-3-5-sonnet-20241022

# Max tokens per LLM response.
LLM_MAX_TOKENS=4096

# Temperature (0.0 = most deterministic / least likely to hallucinate).
LLM_TEMPERATURE=0.0

# ── Google Workspace ──────────────────────────────────────────────────────────
# Path to your Google OAuth2 credentials JSON (from Google Cloud Console).
GOOGLE_CREDENTIALS_FILE=config/google_credentials.json

# Optional: Google Calendar event ID for the meeting to monitor.
MEET_CALENDAR_EVENT_ID=

# ── Operations Manager ────────────────────────────────────────────────────────
# Email address of Benjamin J. Snider for escalation notices.
OPS_MANAGER_EMAIL=

# ── Anti-hallucination ────────────────────────────────────────────────────────
# Confidence threshold below which Digo will escalate instead of answering.
# Range: 0.0 – 1.0 (default: 0.85)
CONFIDENCE_THRESHOLD=0.85
